{
  "name": "dash-proto-vercel",
  "version": "1.0.0",
  "scripts": {
    "build": "mkdir public && cp -r prototype/* public/ && mv public/standalone.html public/index.html",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "extension/core/config.js",
      "extension/content.js"
    ]
  }
}
