<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 모든 연결에 HTTPS 강제 (cleartext HTTP 차단) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
