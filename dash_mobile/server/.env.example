# --- Backend Server Configuration ---
# Change PORT for local testing, cloud platforms usually set it automatically
PORT=3000

# --- Database Configuration (MySQL) ---
# Replace with your Cloud DB credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=dash_db

# --- Firebase Configuration (Optional for FCM) ---
# Paste the content of your service-account-file.json here as a single-line string
# (Only needed if NOT using the physical .json file)
FIREBASE_SERVICE_ACCOUNT=
