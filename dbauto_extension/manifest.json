{
    "manifest_version": 3,
    "name": "Dash · 초간단 아동학대정보시스템 DB 입력기",
    "version": "2.1",
    "description": "엑셀 파일 연동·윈도우창 일괄 기입으로 DB 입력 업무를 단순화합니다.",
    "permissions": [
        "storage",
        "tabs",
        "sidePanel"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "db 자동입력기",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://localhost/*",
                "*://ncads.go.kr/*",
                "*://*.ncads.go.kr/*"
            ],
            "js": [
                "core/config.js",
                "core/message-types.js",
                "content.js"
            ]
        }
    ]
}