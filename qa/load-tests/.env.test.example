# ============================================================
# Dash QA - Load Test 환경변수 설정 예시
# 이 파일을 .env.test 로 복사 후 실제 값 입력
# ============================================================

# 테스트 대상 서버 (절대 프로덕션 사용 금지 - stress/spike 테스트)
BASE_URL=https://staging.dash.qpon

# Firebase ID Token (테스트용 계정으로 로그인 후 획득)
# Flutter: FirebaseAuth.instance.currentUser?.getIdToken()
# Extension: firebase.auth().currentUser.getIdToken()
TEST_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# Firebase UID
TEST_USER_ID=abc123xyz

# 테스트 계정 이메일
TEST_EMAIL=qa-test@example.com

# 공유 레코드 토큰 (테스트용 레코드 생성 후 획득)
TEST_SHARE_TOKEN=test-share-token-abc123
